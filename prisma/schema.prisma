generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}

model User {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  email    String @unique
  password String
  games    Game[]
}

model Game {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  platform  String
  genre     String
  status    String
  createdAt DateTime @default(now())
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
}